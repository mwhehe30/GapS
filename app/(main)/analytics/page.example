'use client';

import { useEffect, useState } from 'react';
import { supabase } from '@/lib/supabase';
import { useRouter } from 'next/navigation';
import {
  getAnalysis,
  getJobRoles,
  getSkills,
  generateRoadmap,
} from '@/lib/api';
import {
  Target,
  Briefcase,
  CheckCircle,
  XCircle,
  Loader2,
  ArrowRight,
  TrendingUp,
  AlertCircle,
} from 'lucide-react';

export default function AnalyticsPage() {
  const router = useRouter();
  const [user, setUser] = useState(null);
  const [sessionToken, setSessionToken] = useState(null);
  const [loading, setLoading] = useState(true);

  // Form states
  const [currentPosition, setCurrentPosition] = useState('');
  const [targetRoleId, setTargetRoleId] = useState('');
  const [selectedSkills, setSelectedSkills] = useState([]);

  // Data states
  const [jobRoles, setJobRoles] = useState([]);
  const [allSkills, setAllSkills] = useState([]);
  const [analysis, setAnalysis] = useState(null);
  const [analysisLoading, setAnalysisLoading] = useState(false);
  const [roadmapLoading, setRoadmapLoading] = useState(false);

  // UI states
  const [showSkillsForm, setShowSkillsForm] = useState(false);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState(null);
  const [hasAnalyzed, setHasAnalyzed] = useState(false);

  // Fetch user and session
  useEffect(() => {
    const init = async () => {
      const {
        data: { user },
      } = await supabase.auth.getUser();
      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (!user) {
        router.push('/signin');
        return;
      }

      setUser(user);
      setSessionToken(session.access_token);

      // Fetch profile data
      const { data: profile } = await supabase
        .from('profiles')
        .select('current_position, target_role_id')
        .eq('id', user.id)
        .single();

      if (profile) {
        setCurrentPosition(profile.current_position || '');
        setTargetRoleId(profile.target_role_id || '');
      }

      // Fetch user's skills
      const { data: userSkills } = await supabase
        .from('user_skills')
        .select('skill_id')
        .eq('user_id', user.id);

      setSelectedSkills(userSkills?.map((s) => s.skill_id) || []);

      setLoading(false);
    };

    init();
  }, [router]);

  // Fetch job roles and skills
  useEffect(() => {
    if (!sessionToken) return;

    const fetchData = async () => {
      try {
        const [rolesData, skillsData] = await Promise.all([
          getJobRoles(),
          getSkills(),
        ]);
        setJobRoles(rolesData.roles || []);
        setAllSkills(skillsData.skills || []);
      } catch (err) {
        setError(err.message);
      }
    };

    fetchData();
  }, [sessionToken]);

  // Handle profile update
  const handleProfileUpdate = async (e) => {
    e.preventDefault();
    setSaving(true);
    setError(null);

    try {
      const { error } = await supabase
        .from('profiles')
        .upsert({
          id: user.id,
          current_position: currentPosition,
          target_role_id: targetRoleId || null,
        })
        .select();

      if (error) throw error;
    } catch (err) {
      setError(err.message);
    } finally {
      setSaving(false);
    }
  };

  // Handle analyze
  const handleAnalyze = async () => {
    if (!currentPosition || !targetRoleId) {
      setError('Please fill in your current position and target role first');
      return;
    }

    setAnalysisLoading(true);
    setError(null);

    try {
      const analysisData = await getAnalysis(sessionToken);
      setAnalysis(analysisData);
      setHasAnalyzed(true);
    } catch (err) {
      setError(err.message);
    } finally {
      setAnalysisLoading(false);
    }
  };

  // Handle skill toggle
  const handleSkillToggle = async (skillId) => {
    setError(null);
    const isAdding = !selectedSkills.includes(skillId);

    try {
      if (isAdding) {
        const { error } = await supabase
          .from('user_skills')
          .insert({ user_id: user.id, skill_id: skillId });
        if (error) throw error;
        setSelectedSkills([...selectedSkills, skillId]);
      } else {
        const { error } = await supabase
          .from('user_skills')
          .delete()
          .eq('user_id', user.id)
          .eq('skill_id', skillId);
        if (error) throw error;
        setSelectedSkills(selectedSkills.filter((id) => id !== skillId));
      }

      // Refresh analysis if already analyzed
      if (hasAnalyzed) {
        const analysisData = await getAnalysis(sessionToken);
        setAnalysis(analysisData);
      }
    } catch (err) {
      setError(err.message);
    }
  };

  // Handle roadmap generation
  const handleGenerateRoadmap = async () => {
    setRoadmapLoading(true);
    setError(null);

    try {
      const result = await generateRoadmap(sessionToken);
      if (result.roadmap) {
        router.push('/roadmap');
      } else {
        setError(result.message || 'No roadmap generated');
      }
    } catch (err) {
      setError(err.message);
    } finally {
      setRoadmapLoading(false);
    }
  };

  // Group skills by category
  const skillsByCategory = allSkills.reduce((acc, skill) => {
    const category = skill.category || 'Other';
    if (!acc[category]) acc[category] = [];
    acc[category].push(skill);
    return acc;
  }, {});

  if (loading) {
    return (
      <div className='min-h-screen flex items-center justify-center'>
        <Loader2 className='w-8 h-8 animate-spin text-gray-900' />
      </div>
    );
  }

  return (
    <div className='min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12 px-4'>
      <div className='max-w-6xl mx-auto space-y-8'>
        {/* Header */}
        <div className='text-center mb-12'>
          <div className='flex items-center justify-center gap-3 mb-4'>
            <div className='p-3 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl shadow-lg'>
              <TrendingUp className='w-8 h-8 text-white' />
            </div>
          </div>
          <h1 className='text-5xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent mb-3'>
            Skill Gap Analytics
          </h1>
          <p className='text-gray-600 text-lg max-w-2xl mx-auto'>
            Discover your career readiness and build a personalized path to your
            dream role
          </p>
        </div>

        {/* Error Display */}
        {error && (
          <div className='bg-red-50 border border-red-200 text-red-700 px-6 py-4 rounded-xl flex items-center gap-3'>
            <AlertCircle className='w-5 h-5 flex-shrink-0' />
            {error}
          </div>
        )}

        {/* Step 1: Profile Setup */}
        <div className='bg-white rounded-3xl shadow-xl p-8 border border-gray-100'>
          <div className='flex items-center gap-4 mb-6'>
            <div className='w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 font-bold'>
              1
            </div>
            <h2 className='text-2xl font-bold text-gray-900'>
              Set Your Career Path
            </h2>
          </div>

          <form
            onSubmit={handleProfileUpdate}
            className='grid md:grid-cols-2 gap-6'
          >
            {/* Current Position */}
            <div>
              <label className='block text-sm font-semibold text-gray-700 mb-2'>
                <Briefcase className='w-4 h-4 inline mr-1' />
                Current Position
              </label>
              <input
                type='text'
                value={currentPosition}
                onChange={(e) => setCurrentPosition(e.target.value)}
                placeholder='e.g., Junior Developer, Student, Fresh Graduate'
                className='w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all'
                required
              />
            </div>

            {/* Target Role */}
            <div>
              <label className='block text-sm font-semibold text-gray-700 mb-2'>
                <Target className='w-4 h-4 inline mr-1' />
                Target Role
              </label>
              <select
                value={targetRoleId}
                onChange={(e) => setTargetRoleId(e.target.value)}
                className='w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all'
                required
              >
                <option value=''>Select your dream role</option>
                {jobRoles.map((role) => (
                  <option key={role.id} value={role.id}>
                    {role.name}
                  </option>
                ))}
              </select>
            </div>

            <div className='md:col-span-2'>
              <button
                type='submit'
                disabled={saving || !currentPosition}
                className='w-full md:w-auto px-8 py-3 bg-gray-900 text-white rounded-xl font-semibold hover:bg-gray-800 disabled:opacity-50 disabled:cursor-not-allowed transition-all flex items-center justify-center gap-2'
              >
                {saving ? (
                  <Loader2 className='w-5 h-5 animate-spin' />
                ) : (
                  'Save Profile'
                )}
              </button>
            </div>
          </form>
        </div>

        {/* Step 2: Analyze Button */}
        {currentPosition && targetRoleId && !hasAnalyzed && (
          <div className='text-center'>
            <button
              onClick={handleAnalyze}
              disabled={analysisLoading}
              className='px-12 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 transition-all flex items-center gap-3 mx-auto'
            >
              {analysisLoading ? (
                <Loader2 className='w-6 h-6 animate-spin' />
              ) : (
                <>
                  <TrendingUp className='w-6 h-6' />
                  Analyze My Skills
                </>
              )}
            </button>
          </div>
        )}

        {/* Analysis Results */}
        {hasAnalyzed && analysis && (
          <>
            {/* Readiness Score Card */}
            <div className='bg-gradient-to-br from-indigo-600 to-purple-700 rounded-3xl shadow-xl p-8 text-white'>
              <h2 className='text-2xl font-bold text-center mb-8'>
                Your Readiness Score
              </h2>
              <div className='flex flex-col md:flex-row items-center justify-center gap-8'>
                <div className='relative w-48 h-48'>
                  <svg className='w-full h-full transform -rotate-90'>
                    <circle
                      cx='96'
                      cy='96'
                      r='88'
                      fill='none'
                      stroke='rgba(255,255,255,0.2)'
                      strokeWidth='16'
                    />
                    <circle
                      cx='96'
                      cy='96'
                      r='88'
                      fill='none'
                      stroke='white'
                      strokeWidth='16'
                      strokeDasharray={`${(analysis.readinessScore / 100) * 552.92} 552.92`}
                      strokeLinecap='round'
                      className='transition-all duration-1000 ease-out'
                    />
                  </svg>
                  <div className='absolute inset-0 flex items-center justify-center'>
                    <div className='text-center'>
                      <div className='text-6xl font-bold'>
                        {analysis.readinessScore}%
                      </div>
                      <div className='text-sm text-indigo-200 mt-1'>Ready</div>
                    </div>
                  </div>
                </div>
                <div className='grid grid-cols-3 gap-6 text-center'>
                  <div className='bg-white/10 rounded-2xl p-4 backdrop-blur-sm'>
                    <div className='text-3xl font-bold'>
                      {analysis.totalRequired}
                    </div>
                    <div className='text-sm text-indigo-200 mt-1'>
                      Total Skills
                    </div>
                  </div>
                  <div className='bg-green-400/20 rounded-2xl p-4 backdrop-blur-sm'>
                    <div className='text-3xl font-bold text-green-300'>
                      {analysis.masteredCount}
                    </div>
                    <div className='text-sm text-green-200 mt-1'>Mastered</div>
                  </div>
                  <div className='bg-red-400/20 rounded-2xl p-4 backdrop-blur-sm'>
                    <div className='text-3xl font-bold text-red-300'>
                      {analysis.gapSkills?.length || 0}
                    </div>
                    <div className='text-sm text-red-200 mt-1'>To Learn</div>
                  </div>
                </div>
              </div>
            </div>

            {/* Skills Management */}
            <div className='bg-white rounded-3xl shadow-xl p-8 border border-gray-100'>
              <div className='flex items-center justify-between mb-6'>
                <div className='flex items-center gap-3'>
                  <div className='p-3 bg-purple-100 rounded-xl'>
                    <CheckCircle className='w-6 h-6 text-purple-600' />
                  </div>
                  <div>
                    <h2 className='text-xl font-bold text-gray-900'>
                      Your Skills
                    </h2>
                    <p className='text-sm text-gray-500'>
                      {selectedSkills.length} skills owned
                    </p>
                  </div>
                </div>
                <button
                  onClick={() => setShowSkillsForm(!showSkillsForm)}
                  className='px-6 py-3 bg-purple-600 text-white rounded-xl font-semibold hover:bg-purple-700 transition-colors flex items-center gap-2'
                >
                  {showSkillsForm ? (
                    'Done'
                  ) : (
                    <>
                      <TrendingUp className='w-4 h-4' />
                      Update Skills
                    </>
                  )}
                </button>
              </div>

              {/* Skills Form */}
              {showSkillsForm && (
                <div className='mb-6 p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-2xl'>
                  <h3 className='text-lg font-bold text-gray-900 mb-4'>
                    Select Skills You Have Mastered
                  </h3>
                  <div className='space-y-6 max-h-96 overflow-y-auto pr-2'>
                    {Object.entries(skillsByCategory).map(
                      ([category, skills]) => (
                        <div key={category}>
                          <h4 className='text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide'>
                            {category}
                          </h4>
                          <div className='grid grid-cols-2 md:grid-cols-3 gap-2'>
                            {skills.map((skill) => (
                              <button
                                key={skill.id}
                                onClick={() => handleSkillToggle(skill.id)}
                                className={`px-4 py-3 rounded-xl text-sm font-medium transition-all ${
                                  selectedSkills.includes(skill.id)
                                    ? 'bg-green-500 text-white shadow-lg scale-105'
                                    : 'bg-white text-gray-700 border-2 border-gray-200 hover:border-green-400 hover:shadow-md'
                                }`}
                              >
                                <div className='flex items-center justify-between'>
                                  <span>{skill.name}</span>
                                  {selectedSkills.includes(skill.id) && (
                                    <CheckCircle className='w-4 h-4' />
                                  )}
                                </div>
                              </button>
                            ))}
                          </div>
                        </div>
                      ),
                    )}
                  </div>
                </div>
              )}

              {/* Skills Overview */}
              <div className='space-y-6'>
                {/* Mastered Skills */}
                <div>
                  <h3 className='text-lg font-bold text-gray-900 mb-4 flex items-center gap-2'>
                    <div className='w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center'>
                      <CheckCircle className='w-5 h-5 text-green-600' />
                    </div>
                    Mastered Skills ({analysis.masteredSkills?.length || 0})
                  </h3>
                  {analysis.masteredSkills?.length > 0 ? (
                    <div className='grid grid-cols-2 md:grid-cols-4 gap-3'>
                      {analysis.masteredSkills.map((skill) => (
                        <div
                          key={skill.id}
                          className='flex items-center gap-3 px-4 py-3 bg-green-50 border border-green-200 rounded-xl'
                        >
                          <CheckCircle className='w-5 h-5 text-green-500 flex-shrink-0' />
                          <div className='min-w-0'>
                            <div className='font-medium text-gray-900 truncate'>
                              {skill.name}
                            </div>
                            <div className='text-xs text-gray-500'>
                              {skill.category}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <p className='text-gray-500 text-sm py-4 bg-gray-50 rounded-xl text-center'>
                      No mastered skills yet. Click "Update Skills" to add some!
                    </p>
                  )}
                </div>

                {/* Gap Skills */}
                {analysis.gapSkills?.length > 0 && (
                  <div>
                    <h3 className='text-lg font-bold text-gray-900 mb-4 flex items-center gap-2'>
                      <div className='w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center'>
                        <XCircle className='w-5 h-5 text-red-600' />
                      </div>
                      Skills to Learn ({analysis.gapSkills.length})
                    </h3>
                    <div className='grid grid-cols-2 md:grid-cols-4 gap-3'>
                      {analysis.gapSkills.map((skill) => (
                        <div
                          key={skill.id}
                          className='flex items-center gap-3 px-4 py-3 bg-red-50 border border-red-200 rounded-xl'
                        >
                          <XCircle className='w-5 h-5 text-red-500 flex-shrink-0' />
                          <div className='min-w-0'>
                            <div className='font-medium text-gray-900 truncate'>
                              {skill.name}
                            </div>
                            <div className='text-xs text-gray-500'>
                              {skill.category}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {/* Nice to Have Skills */}
                {analysis.niceToHaveSkills?.length > 0 && (
                  <div>
                    <h3 className='text-lg font-bold text-gray-900 mb-4 flex items-center gap-2'>
                      <div className='w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center'>
                        <Briefcase className='w-5 h-5 text-yellow-600' />
                      </div>
                      Nice to Have ({analysis.niceToHaveSkills.length})
                    </h3>
                    <div className='grid grid-cols-2 md:grid-cols-4 gap-3'>
                      {analysis.niceToHaveSkills.map((skill) => (
                        <div
                          key={skill.id}
                          className='flex items-center gap-3 px-4 py-3 bg-yellow-50 border border-yellow-200 rounded-xl'
                        >
                          <Briefcase className='w-5 h-5 text-yellow-500 flex-shrink-0' />
                          <div className='min-w-0'>
                            <div className='font-medium text-gray-900 truncate'>
                              {skill.name}
                            </div>
                            <div className='text-xs text-gray-500'>
                              {skill.category}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>

            {/* Generate Roadmap CTA */}
            {analysis.gapSkills?.length > 0 && (
              <div className='bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 rounded-3xl shadow-xl p-10 text-white text-center'>
                <h2 className='text-3xl font-bold mb-4'>
                  Ready to Bridge the Gap?
                </h2>
                <p className='text-indigo-100 mb-8 max-w-2xl mx-auto text-lg'>
                  Generate a personalized learning roadmap with step-by-step
                  guidance to reach your target role.
                </p>
                <button
                  onClick={handleGenerateRoadmap}
                  disabled={roadmapLoading}
                  className='inline-flex items-center gap-3 px-10 py-4 bg-white text-indigo-600 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 transition-all'
                >
                  {roadmapLoading ? (
                    <Loader2 className='w-6 h-6 animate-spin' />
                  ) : (
                    <>
                      Generate My Roadmap
                      <ArrowRight className='w-6 h-6' />
                    </>
                  )}
                </button>
              </div>
            )}
          </>
        )}
      </div>
    </div>
  );
}
