'use client';

import { useEffect, useState } from 'react';
import { supabase } from '@/lib/supabase';
import { useRouter } from 'next/navigation';
import { getRoadmap, generateRoadmap } from '@/lib/api';
import Skeleton from '@/components/Skeleton';
import {
  Loader2,
  BookOpen,
  Clock,
  TrendingUp,
  ExternalLink,
  ChevronDown,
  ChevronUp,
  Sparkles,
  AlertCircle,
  ArrowLeft,
  BarChart2,
  Layers,
} from 'lucide-react';

const TYPE_COLOR = {
  video: 'bg-red-100 text-red-700',
  article: 'bg-blue-100 text-blue-700',
  course: 'bg-purple-100 text-purple-700',
};

function ResourceCard({ resource }) {
  return (
    <a
      href={resource.url}
      target='_blank'
      rel='noopener noreferrer'
      className='flex items-start gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-indigo-300 hover:shadow-md transition-all group'
    >
      <div className='flex-1 min-w-0'>
        <p className='text-sm font-medium text-gray-900 group-hover:text-indigo-600 transition-colors truncate'>
          {resource.title}
        </p>
        <div className='flex items-center gap-2 mt-1'>
          <span
            className={`text-xs px-2 py-0.5 rounded-full font-medium ${TYPE_COLOR[resource.type] || 'bg-gray-100 text-gray-600'}`}
          >
            {resource.type}
          </span>
          {resource.platform && (
            <span className='text-xs text-gray-400'>{resource.platform}</span>
          )}
        </div>
      </div>
      <ExternalLink className='w-4 h-4 text-gray-400 group-hover:text-indigo-500 flex-shrink-0 mt-0.5 transition-colors' />
    </a>
  );
}

function PhaseCard({ phase, index }) {
  const [open, setOpen] = useState(index === 0);

  return (
    <div className='bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden'>
      {/* Phase header */}
      <button
        onClick={() => setOpen(!open)}
        className='w-full flex items-center gap-4 p-6 text-left hover:bg-gray-50 transition-colors'
      >
        <div className='w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold flex-shrink-0'>
          {phase.phase}
        </div>
        <div className='flex-1 min-w-0'>
          <h3 className='font-bold text-gray-900 text-lg'>{phase.title}</h3>
          <div className='flex items-center gap-3 mt-1 flex-wrap'>
            <span className='flex items-center gap-1 text-xs text-gray-500'>
              <Clock className='w-3 h-3' />
              {phase.duration}
            </span>
            <span className='flex items-center gap-1 text-xs text-gray-500'>
              <Layers className='w-3 h-3' />
              {phase.focus_skills?.length || 0} skills
            </span>
          </div>
        </div>
        {open ? (
          <ChevronUp className='w-5 h-5 text-gray-400 flex-shrink-0' />
        ) : (
          <ChevronDown className='w-5 h-5 text-gray-400 flex-shrink-0' />
        )}
      </button>

      {open && (
        <div className='px-6 pb-6 space-y-5 border-t border-gray-100 pt-5'>
          {/* Focus Skills */}
          {phase.focus_skills?.length > 0 && (
            <div>
              <p className='text-xs font-bold text-gray-500 uppercase tracking-wide mb-2'>
                Focus Skills
              </p>
              <div className='flex flex-wrap gap-2'>
                {phase.focus_skills.map((skill) => (
                  <span
                    key={skill}
                    className='px-3 py-1 bg-indigo-50 text-indigo-700 rounded-full text-sm font-medium'
                  >
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          )}

          {/* Sub Topics */}
          {phase.sub_topics?.length > 0 && (
            <div>
              <p className='text-xs font-bold text-gray-500 uppercase tracking-wide mb-2'>
                Topics
              </p>
              <ul className='space-y-1'>
                {phase.sub_topics.map((topic, i) => (
                  <li
                    key={i}
                    className='flex items-start gap-2 text-sm text-gray-700'
                  >
                    <span className='w-1.5 h-1.5 rounded-full bg-indigo-400 mt-2 flex-shrink-0' />
                    {topic}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Resources */}
          {phase.resources?.length > 0 && (
            <div>
              <p className='text-xs font-bold text-gray-500 uppercase tracking-wide mb-2'>
                Resources
              </p>
              <div className='grid sm:grid-cols-2 gap-2'>
                {phase.resources.map((r, i) => (
                  <ResourceCard key={i} resource={r} />
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

export default function RoadmapPage() {
  const router = useRouter();
  const [sessionToken, setSessionToken] = useState(null);
  const [roadmap, setRoadmap] = useState(null);
  const [loading, setLoading] = useState(true);
  const [generating, setGenerating] = useState(false);
  const [error, setError] = useState(null);

  useEffect(() => {
    const init = async () => {
      const {
        data: { user },
      } = await supabase.auth.getUser();
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!user) {
        router.push('/signin');
        return;
      }
      setSessionToken(session.access_token);
      try {
        const data = await getRoadmap(session.access_token);
        setRoadmap(data.roadmap);
      } catch (err) {
        if (!err?.message?.includes('Cannot coerce')) {
          setError(err.message);
        } else {
          setError(null);
        }
      } finally {
        setLoading(false);
      }
    };
    init();
  }, [router]);

  const handleGenerate = async () => {
    setGenerating(true);
    setError(null);
    try {
      const result = await generateRoadmap(sessionToken);
      if (result.roadmap) setRoadmap(result.roadmap);
      else setError(result.message || 'No roadmap generated');
    } catch (err) {
      setError(err.message);
    } finally {
      setGenerating(false);
    }
  };

  if (loading) {
    return null;
  }

  const content = roadmap?.content;

  return (
    <div className='min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12 px-4'>
      <div className='max-w-4xl mx-auto space-y-6'>
        {/* Header */}
        <div className='flex items-center gap-3 mb-2'>
          <button
            onClick={() => router.push('/analytics')}
            className='p-2 rounded-xl hover:bg-white hover:shadow-sm transition-all text-gray-500 hover:text-gray-900'
          >
            <ArrowLeft className='w-5 h-5' />
          </button>
          <div>
            <h1 className='text-3xl font-bold text-gray-900'>
              Learning Roadmap
            </h1>
            {roadmap && (
              <p className='text-sm text-gray-500 mt-0.5'>
                Target:{' '}
                <span className='font-medium text-indigo-600'>
                  {roadmap.job_roles?.name}
                </span>
              </p>
            )}
          </div>
        </div>

        {/* Error */}
        {error && (
          <div className='bg-red-50 border border-red-200 text-red-700 px-5 py-4 rounded-xl flex items-center gap-3'>
            <AlertCircle className='w-5 h-5 flex-shrink-0' />
            {error}
          </div>
        )}

        {/* No roadmap state */}
        {!roadmap && !error && (
          <div className='bg-white rounded-3xl shadow-xl p-12 text-center border border-gray-100'>
            <div className='w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-4'>
              <BookOpen className='w-8 h-8 text-indigo-600' />
            </div>
            <h2 className='text-2xl font-bold text-gray-900 mb-2'>
              No Roadmap Yet
            </h2>
            <p className='text-gray-500 mb-8 max-w-md mx-auto'>
              Generate a personalized learning roadmap based on your skill gaps
              and target role.
            </p>
            <button
              onClick={handleGenerate}
              disabled={generating}
              className='inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl font-semibold hover:shadow-lg hover:scale-105 disabled:opacity-50 disabled:hover:scale-100 transition-all'
            >
              {generating ? (
                <Loader2 className='w-5 h-5 animate-spin' />
              ) : (
                <>
                  <Sparkles className='w-5 h-5' />
                  Generate Roadmap
                </>
              )}
            </button>
          </div>
        )}

        {/* Roadmap content */}
        {roadmap && content && (
          <>
            {/* Summary card */}
            <div className='bg-gradient-to-br from-indigo-600 to-purple-700 rounded-2xl p-6 text-white'>
              <div className='flex items-start justify-between gap-4 flex-wrap'>
                <div className='flex-1'>
                  <p className='text-indigo-200 text-sm font-medium mb-1'>
                    Overview
                  </p>
                  <p className='text-white leading-relaxed'>
                    {content.summary}
                  </p>
                </div>
                <div className='flex gap-4 flex-shrink-0'>
                  <div className='text-center'>
                    <div className='flex items-center gap-1 text-indigo-200 text-xs mb-1'>
                      <Clock className='w-3 h-3' />
                      Duration
                    </div>
                    <p className='font-bold text-white text-sm'>
                      {content.estimatedDuration}
                    </p>
                  </div>
                  <div className='text-center'>
                    <div className='flex items-center gap-1 text-indigo-200 text-xs mb-1'>
                      <BarChart2 className='w-3 h-3' />
                      Phases
                    </div>
                    <p className='font-bold text-white text-sm'>
                      {content.phases?.length || 0}
                    </p>
                  </div>
                </div>
              </div>
            </div>

            {/* Market Insight */}
            {content.marketInsight && (
              <div className='flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl px-5 py-4'>
                <TrendingUp className='w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5' />
                <div>
                  <p className='text-xs font-bold text-amber-700 uppercase tracking-wide mb-1'>
                    Market Insight
                  </p>
                  <p className='text-sm text-amber-800'>
                    {content.marketInsight}
                  </p>
                </div>
              </div>
            )}

            {/* Phases */}
            <div className='space-y-4'>
              {content.phases?.map((phase, i) => (
                <PhaseCard key={phase.phase} phase={phase} index={i} />
              ))}
            </div>

            {/* Regenerate */}
            <div className='text-center pt-4'>
              <button
                onClick={handleGenerate}
                disabled={generating}
                className='inline-flex items-center gap-2 px-6 py-3 bg-white border border-gray-200 text-gray-700 rounded-xl font-medium hover:border-indigo-300 hover:shadow-md disabled:opacity-50 transition-all'
              >
                {generating ? (
                  <Loader2 className='w-4 h-4 animate-spin' />
                ) : (
                  <>
                    <Sparkles className='w-4 h-4 text-indigo-500' />
                    Regenerate Roadmap
                  </>
                )}
              </button>
            </div>
          </>
        )}
      </div>
    </div>
  );
}
